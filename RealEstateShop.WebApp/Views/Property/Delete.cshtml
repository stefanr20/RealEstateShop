@* Delete.cshtml *@
@model RealEstate.BLL.Models.PropertyViewModel

@{
    ViewData["Title"] = "Delete Property";
}

<h2>Delete Property</h2>
<p>Are you sure you want to delete this property?</p>

<table class="table">
    <tr><th>Title</th><td>@Model.Title</td></tr>
    <tr><th>Description</th><td>@Model.Description</td></tr>
    <tr><th>Price</th><td>@Model.Price</td></tr>
    <tr><th>City</th><td>@Model.City</td></tr>
    <tr><th>Street</th><td>@Model.Street</td></tr>
    <tr><th>Country</th><td>@Model.Country</td></tr>
</table>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>